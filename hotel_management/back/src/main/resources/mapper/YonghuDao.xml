<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.YonghuDao">

	<!-- 可根据自己的需求，是否要使�?-->
    <resultMap type="com.entity.YonghuEntity" id="customerMap">
        <result property="customerming" column="customerming"/>
        <result property="xingming" column="xingming"/>
        <result property="mima" column="mima"/>
        <result property="xingbie" column="xingbie"/>
        <result property="nianling" column="nianling"/>
        <result property="shoujihao" column="shoujihao"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.YonghuVO" >
		SELECT * FROM customer  customer         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.YonghuVO" >
		SELECT  customer.* FROM customer  customer 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.YonghuView" >

		SELECT  customer.* FROM customer  customer 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.YonghuView" >
		SELECT * FROM customer  customer <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
