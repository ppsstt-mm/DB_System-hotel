<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.NewsDao">

	<!-- 可根据自己的需求，是否要使�?-->
    <resultMap type="com.entity.NewsEntity" id="noticeMap">
        <result property="title" column="title"/>
        <result property="introduction" column="introduction"/>
        <result property="picture" column="picture"/>
        <result property="content" column="content"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.NewsVO" >
		SELECT * FROM notice  notice         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.NewsVO" >
		SELECT  notice.* FROM notice  notice 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.NewsView" >

		SELECT  notice.* FROM notice  notice 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.NewsView" >
		SELECT * FROM notice  notice <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
