<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.DiscussjiudiankefangDao">

	<!-- 可根据自己的需求，是否要使�?-->
    <resultMap type="com.entity.DiscussjiudiankefangEntity" id="room_reviewMap">
        <result property="refid" column="refid"/>
        <result property="userid" column="userid"/>
        <result property="nickname" column="nickname"/>
        <result property="content" column="content"/>
        <result property="reply" column="reply"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.DiscussjiudiankefangVO" >
		SELECT * FROM room_review  room_review         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.DiscussjiudiankefangVO" >
		SELECT  room_review.* FROM room_review  room_review 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.DiscussjiudiankefangView" >

		SELECT  room_review.* FROM room_review  room_review 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.DiscussjiudiankefangView" >
		SELECT * FROM room_review  room_review <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
